# ============================================================
# Arvion AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Prolixis Continuum (AI Memory + LLM) ─────────────────────
# Get your key from https://dashboard.prolixis.in
PROLIXIS_API_KEY=px_live_77381644e5108828b21bbffa6e19f7d2c26998074eafcb80c4adc776d7c6b686
PROLIXIS_BASE_URL=https://api.prolixis.in

# ── Embedding Model (local FAISS search) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_CONFIDENCE_THRESHOLD=0.75

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ── Frontend URL (for CORS) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
